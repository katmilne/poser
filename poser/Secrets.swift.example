enum Secrets {
    /// Copy this file to `Secrets.swift` (gitignored) and fill in the real
    /// RevenueCat public Apple API key for `space.concurrent.poser`.
    /// Until it is filled in, the store runs "offline": paywalls render with
    /// the fallback catalog and purchasing is disabled.
    static let revenueCatAPIKey = "appl_REPLACE_WITH_POSER_PUBLIC_KEY"

    /// Sentry DSN for the Poser project (getsentry.com). Until it is filled
    /// in, `Analytics.configure()` skips Sentry entirely and no crash/error
    /// reports are sent.
    static let sentryDSN = "https://REPLACE_WITH_POSER_SENTRY_DSN"

    /// Aptabase app key for the Poser project (aptabase.com), formatted
    /// `A-REGION-XXXXXXXXXX`. Until it is filled in, `Analytics.configure()`
    /// skips Aptabase entirely and no product-analytics events are sent.
    static let aptabaseAppKey = "A-REPLACE-WITH-POSER-APP-KEY"
}
